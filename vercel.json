{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    // Rewrite API calls to the backend service. Vercel does not interpolate
    // environment variables inside this file, so you must either replace
    // `https://api.example.com` with your actual backend URL here or set up
    // an equivalent rewrite rule in the Vercel dashboard that uses the
    // `BACKEND_URL` env var.
    { "src": "/api/(.*)", "dest": "https://api.example.com/api/$1" },
    { "src": "/(.*)", "dest": "/dist/public/$1" }
  ]
}
